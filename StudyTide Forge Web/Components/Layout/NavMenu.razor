@implements IDisposable
@inject NavigationManager Navigation
@inject AppShellStateService ShellState

<nav class="nav-root">
    <div class="brand-panel">
        <div class="brand-title">StudyTide Forge</div>
        <div class="brand-subtitle">Software + Cloud Developer Training</div>
    </div>

    <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">Dashboard</NavLink>
    <div class="nav-group">
        <div class="nav-group-label">Training Materials</div>
        <a class="@GetStudyLibraryClass()" href="/modules">Study Library</a>
        <NavLink class="nav-link nav-sublink" href="/modules/flashcards" Match="NavLinkMatch.All">Flashcards</NavLink>
        <NavLink class="nav-link nav-sublink" href="/modules/flagged" Match="NavLinkMatch.All">Flagged Material</NavLink>
    </div>
    <NavLink class="nav-link" href="/practice">Practice</NavLink>

    @if (ShellState.ShowMediaPlayer)
    {
        <MediaPlayerPanel />
    }
</nav>

@code {
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
        ShellState.Changed += HandleShellStateChanged;
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
        ShellState.Changed -= HandleShellStateChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs eventArgs)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleShellStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private string GetStudyLibraryClass()
    {
        return IsStudyLibraryRoute()
            ? "nav-link nav-sublink active"
            : "nav-link nav-sublink";
    }

    private bool IsStudyLibraryRoute()
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var path = relativePath.Split('?', '#')[0];
        var segments = path.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (segments.Length == 0)
        {
            return false;
        }

        if (!string.Equals(segments[0], "modules", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (segments.Length == 1)
        {
            return true;
        }

        return int.TryParse(segments[1], out _);
    }
}
