@page "/modules"
@inject StudyLibraryService StudyLibraryService

<PageTitle>Study Library</PageTitle>

<h1>Study Library</h1>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <p class="status-message">@_statusMessage</p>
}

@if (_snapshot is null)
{
    <section class="panel">
        <p>Loading study library...</p>
    </section>
}
else if (_snapshot.Modules.Count == 0)
{
    <section class="panel">
        <p>No modules available.</p>
    </section>
}
else
{
    if (_snapshot.LastResumeTarget is not null)
    {
        <section class="panel library-resume-panel">
            <h2>Resume Last Study Session</h2>
            <p class="meta-text">
                Module: @_snapshot.LastResumeTarget.ModuleName |
                Lesson: @_snapshot.LastResumeTarget.LessonTitle
            </p>
            <div class="actions">
                <a class="button-link" href="@BuildStudyLink(_snapshot.LastResumeTarget.ModuleId, _snapshot.LastResumeTarget.LessonId, resume: true)">Resume</a>
                <a class="button-link secondary" href="@BuildStudyLink(_snapshot.LastResumeTarget.ModuleId, _snapshot.LastResumeTarget.LessonId, resume: false)">Start</a>
                <button class="danger" @onclick="() => ResetLessonAsync(_snapshot.LastResumeTarget.LessonId, _snapshot.LastResumeTarget.LessonTitle)">Reset</button>
            </div>
        </section>
    }

    @foreach (var module in _snapshot.Modules)
    {
        <section class="panel library-module-panel">
            <div class="library-module-header">
                <div>
                    <h2>@module.Name</h2>
                    <p class="meta-text">Category: @module.Category</p>
                </div>
                <div class="library-module-actions">
                    <span class="status-pill @GetStatusClass(module.Status)">@GetStatusLabel(module.Status)</span>
                    @if (module.ResumeTarget is not null)
                    {
                        <a class="button-link" href="@BuildStudyLink(module.ResumeTarget.ModuleId, module.ResumeTarget.LessonId, resume: true)">Resume</a>
                    }
                    @if (module.Lessons.Count > 0)
                    {
                        <a class="button-link secondary" href="@BuildStudyLink(module.ModuleId, module.Lessons[0].LessonId, resume: false)">Study</a>
                    }
                    <a class="button-link secondary" href="/modules/@module.ModuleId">Module Details</a>
                </div>
            </div>

            <div class="library-module-meta">
                <span>Lessons: @module.LessonCount</span>
                <span>Training items: @module.TrainingItemCount</span>
                <span>Flashcards: @module.FlashcardCount</span>
            </div>

            <table class="data-table library-table">
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Lesson</th>
                        <th>Status</th>
                        <th>Progress</th>
                        <th>Training Items</th>
                        <th>Flashcards</th>
                        <th>Last Viewed</th>
                        <th>Study</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lesson in module.Lessons)
                    {
                        <tr>
                            <td>@lesson.OrderIndex</td>
                            <td>
                                @lesson.LessonTitle
                                @if (lesson.IsFlagged)
                                {
                                    <span class="flag-pill">Flagged</span>
                                }
                            </td>
                            <td>
                                <span class="status-pill @GetStatusClass(lesson.Status)">@GetStatusLabel(lesson.Status)</span>
                            </td>
                            <td>@lesson.CompletionPercent.ToString("0.##")%</td>
                            <td>@lesson.BlockCount</td>
                            <td>@lesson.FlashcardCount</td>
                            <td>@(lesson.LastViewedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                            <td>
                                <div class="actions compact-actions">
                                    <a class="button-link secondary" href="@BuildStudyLink(module.ModuleId, lesson.LessonId, resume: false)">Start</a>
                                    <a class="button-link" href="@BuildStudyLink(module.ModuleId, lesson.LessonId, resume: true)">Resume</a>
                                    <button class="danger" @onclick="() => ResetLessonAsync(lesson.LessonId, lesson.LessonTitle)">Reset</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }
}

@code {
    private StudyLibrarySnapshot? _snapshot;
    private string? _statusMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadSnapshotAsync();
    }

    private async Task LoadSnapshotAsync()
    {
        try
        {
            _snapshot = await StudyLibraryService.GetLibrarySnapshotAsync();
        }
        catch (Exception exception)
        {
            _statusMessage = $"Unable to load study library. {exception.Message}";
            Console.Error.WriteLine($"[StudyTide] Unable to load study library. {exception}");
        }
    }

    private async Task ResetLessonAsync(int lessonId, string lessonTitle)
    {
        try
        {
            var resetApplied = await StudyLibraryService.ResetLessonProgressAsync(lessonId);
            _statusMessage = resetApplied
                ? $"Reset study progress for \"{lessonTitle}\"."
                : $"\"{lessonTitle}\" is already at Not Started.";

            await LoadSnapshotAsync();
        }
        catch (Exception exception)
        {
            _statusMessage = $"Unable to reset study progress. {exception.Message}";
            Console.Error.WriteLine($"[StudyTide] Unable to reset lesson progress. {exception}");
        }
    }

    private static string BuildStudyLink(int moduleId, int lessonId, bool resume)
    {
        return $"/modules/{moduleId}/lessons/{lessonId}?resume={resume.ToString().ToLowerInvariant()}";
    }

    private static string GetStatusLabel(StudyProgressStatus status)
    {
        return status switch
        {
            StudyProgressStatus.NotStarted => "Not Started",
            StudyProgressStatus.InProgress => "In Progress",
            StudyProgressStatus.Completed => "Completed",
            _ => "Not Started"
        };
    }

    private static string GetStatusClass(StudyProgressStatus status)
    {
        return status switch
        {
            StudyProgressStatus.NotStarted => "status-not-started",
            StudyProgressStatus.InProgress => "status-in-progress",
            StudyProgressStatus.Completed => "status-completed",
            _ => "status-not-started"
        };
    }
}
