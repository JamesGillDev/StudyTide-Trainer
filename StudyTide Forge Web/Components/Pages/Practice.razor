@page "/practice"
@using System.Text.RegularExpressions
@inject IDbContextFactory<ForgeDbContext> DbFactory
@inject PracticeService PracticeService

<PageTitle>Practice</PageTitle>

<h1>Verbatim Practice</h1>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <p class="status-message">@_statusMessage</p>
}

<section class="panel">
    <h2>Scope</h2>

    <div class="filter-grid">
        <div>
            <label for="moduleScope">Module</label>
            <select id="moduleScope" value="@(_selectedModuleId?.ToString() ?? "all")" @onchange="OnModuleChangedAsync">
                <option value="all">All modules</option>
                @foreach (var module in _modules)
                {
                    <option value="@module.Id">@module.Name</option>
                }
            </select>
        </div>

        <div>
            <label for="lessonScope">Lesson</label>
            <select id="lessonScope" value="@(_selectedLessonId?.ToString() ?? "all")" @onchange="OnLessonChangedAsync">
                <option value="all">All lessons</option>
                @foreach (var lesson in _lessons)
                {
                    <option value="@lesson.Id">@(_selectedModuleId.HasValue ? lesson.Title : lesson.DisplayTitle)</option>
                }
            </select>
        </div>
    </div>

    <div class="actions">
        <button @onclick="LoadNextBlockAsync">Load Next Due Item</button>
    </div>
</section>

<section class="panel instruction-panel">
    <h2>Retype Workflow</h2>
    <div class="instruction-grid">
        <article class="instruction-step">
            <span class="step-badge">1</span>
            <h3>Load a due item</h3>
            <p>Choose module/lesson scope, then load the next due training item.</p>
        </article>
        <article class="instruction-step">
            <span class="step-badge">2</span>
            <h3>Read all three sections</h3>
            <p>Review Prompt, Response, and Example so context is clear before typing.</p>
        </article>
        <article class="instruction-step">
            <span class="step-badge">3</span>
            <h3>Retype values only</h3>
            <p>Type section text in order. Do not type section labels.</p>
        </article>
        <article class="instruction-step">
            <span class="step-badge">4</span>
            <h3>Use Diff Summary</h3>
            <p>Fix weak spots by checking line differences and first mismatch index.</p>
        </article>
    </div>
</section>

@if (_currentBlock is null)
{
    <section class="panel">
        <p>No training item found in the selected scope.</p>
    </section>
}
else
{
    <section class="panel">
        <h2>@_currentBlock.Title</h2>
        <p class="meta-text">
            Lesson: @_currentBlock.Lesson?.Title |
            Difficulty: @_currentBlock.Difficulty
        </p>

        <div class="practice-grid">
            <article>
                <h3>Training content</h3>

                @if (_parsedContent.HasSections)
                {
                    <div class="training-sections">
                        <section class="training-section">
                            <h4>Prompt</h4>
                            <pre class="training-content">@_parsedContent.Prompt</pre>
                        </section>
                        <section class="training-section">
                            <h4>Response</h4>
                            <pre class="training-content">@_parsedContent.Response</pre>
                        </section>
                        <section class="training-section">
                            <h4>Example</h4>
                            <pre class="training-content">@_parsedContent.Example</pre>
                        </section>
                    </div>
                    <p class="meta-text retype-note">Retype only the text values above in this order: Prompt line, Response line, Example line.</p>
                }
                else
                {
                    <pre class="training-content">@_parsedContent.RetypeTarget</pre>
                    <p class="meta-text retype-note">Retype exactly what is shown in the training content panel.</p>
                }
            </article>

            <article>
                <h3>Your verbatim retype</h3>
                <InputTextArea @bind-Value="_typedText" rows="18" class="typing-box" placeholder="@GetTypingPlaceholder()" />
                <div class="typing-hints">
                    <span>Expected chars: @_parsedContent.RetypeTarget.Length</span>
                    <span>Typed chars: @_typedText.Length</span>
                </div>
            </article>
        </div>

        <div class="actions">
            <button @onclick="SubmitAttemptAsync">Submit Attempt</button>
            <button @onclick="LoadNextBlockAsync">Load Another Item</button>
        </div>
    </section>
}

@if (_evaluation is not null)
{
    <section class="panel">
        <h2>Diff Summary</h2>

        <div class="metric-grid">
            <article class="metric-card">
                <h3>Accuracy</h3>
                <p>@_evaluation.AccuracyPercent.ToString("0.00")%</p>
            </article>
            <article class="metric-card">
                <h3>Error count</h3>
                <p>@_evaluation.ErrorCount</p>
            </article>
            <article class="metric-card">
                <h3>Missing chars</h3>
                <p>@_evaluation.MissingCharacters</p>
            </article>
            <article class="metric-card">
                <h3>Extra chars</h3>
                <p>@_evaluation.ExtraCharacters</p>
            </article>
            <article class="metric-card">
                <h3>First mismatch index</h3>
                <p>@(_evaluation.FirstMismatchIndex?.ToString() ?? "None")</p>
            </article>
        </div>

        <h3>Line differences</h3>

        @if (_evaluation.MismatchedLines.Count == 0)
        {
            <p>No line-level differences detected.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Line</th>
                        <th>Expected</th>
                        <th>Typed</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mismatch in _evaluation.MismatchedLines)
                    {
                        <tr>
                            <td>@mismatch.LineNumber</td>
                            <td><code>@mismatch.SourceLine</code></td>
                            <td><code>@mismatch.TypedLine</code></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    private readonly List<ModuleOption> _modules = [];
    private readonly List<LessonOption> _lessons = [];

    private int? _selectedModuleId;
    private int? _selectedLessonId;

    private TrainingBlock? _currentBlock;
    private PracticeEvaluation? _evaluation;
    private ParsedTrainingContent _parsedContent = ParsedTrainingContent.Empty;
    private string _typedText = string.Empty;
    private string? _statusMessage;
    private static readonly Regex LabeledContentPattern = new(
        @"^\s*Prompt:\s*\n(?<prompt>.*?)\n\s*\nResponse:\s*\n(?<response>.*?)\n\s*\nExample:\s*\n(?<example>.*)\s*$",
        RegexOptions.Singleline | RegexOptions.CultureInvariant);

    protected override async Task OnInitializedAsync()
    {
        await LoadModulesAsync();
        await LoadLessonsAsync();
        await LoadNextBlockAsync();
    }

    private async Task LoadModulesAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var modules = await db.TrainingModules
            .AsNoTracking()
            .OrderBy(x => x.Category)
            .ThenBy(x => x.Name)
            .Select(x => new ModuleOption
            {
                Id = x.Id,
                Name = x.Name
            })
            .ToListAsync();

        _modules.Clear();
        _modules.AddRange(modules);
    }

    private async Task LoadLessonsAsync()
    {
        _lessons.Clear();

        await using var db = await DbFactory.CreateDbContextAsync();

        var query = db.TrainingLessons
            .AsNoTracking()
            .Include(x => x.Module)
            .AsQueryable();

        if (_selectedModuleId.HasValue)
        {
            query = query.Where(x => x.ModuleId == _selectedModuleId.Value);
        }

        var lessons = await query
            .OrderBy(x => x.Module!.Name)
            .ThenBy(x => x.OrderIndex)
            .Select(x => new LessonOption
            {
                Id = x.Id,
                Title = x.Title,
                ModuleName = x.Module!.Name
            })
            .ToListAsync();

        _lessons.AddRange(lessons);
    }

    private async Task OnModuleChangedAsync(ChangeEventArgs eventArgs)
    {
        _selectedModuleId = ParseNullableInt(eventArgs.Value?.ToString());
        _selectedLessonId = null;

        await LoadLessonsAsync();
        await LoadNextBlockAsync();
    }

    private async Task OnLessonChangedAsync(ChangeEventArgs eventArgs)
    {
        _selectedLessonId = ParseNullableInt(eventArgs.Value?.ToString());
        await LoadNextBlockAsync();
    }

    private async Task LoadNextBlockAsync()
    {
        _currentBlock = await PracticeService.GetNextDueBlockAsync(_selectedModuleId, _selectedLessonId);
        _typedText = string.Empty;
        _evaluation = null;
        _parsedContent = _currentBlock is null
            ? ParsedTrainingContent.Empty
            : ParseTrainingContent(_currentBlock.Content);

        _statusMessage = _currentBlock is null
            ? "No due training item available in this scope."
            : "Training item loaded. Retype Prompt, Response, and Example text values in order (labels are display-only).";
    }

    private async Task SubmitAttemptAsync()
    {
        if (_currentBlock is null)
        {
            _statusMessage = "Load a training item first.";
            return;
        }

        _evaluation = PracticeService.Evaluate(_parsedContent.RetypeTarget, _typedText);
        await PracticeService.SaveAttemptAsync(_currentBlock.Id, _typedText, _evaluation);

        _statusMessage = "Attempt saved and schedule updated.";
    }

    private static int? ParseNullableInt(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || string.Equals(value, "all", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        return int.TryParse(value, out var parsed)
            ? parsed
            : null;
    }

    private static ParsedTrainingContent ParseTrainingContent(string content)
    {
        var normalized = NormalizeLineEndings(content).Trim();
        var match = LabeledContentPattern.Match(normalized);

        if (!match.Success)
        {
            return new ParsedTrainingContent(string.Empty, string.Empty, string.Empty, normalized, false);
        }

        var prompt = match.Groups["prompt"].Value.Trim();
        var response = match.Groups["response"].Value.Trim();
        var example = match.Groups["example"].Value.Trim();
        var retypeTarget = string.Join("\n", new[] { prompt, response, example }.Where(x => !string.IsNullOrWhiteSpace(x)));
        return new ParsedTrainingContent(prompt, response, example, retypeTarget, true);
    }

    private static string NormalizeLineEndings(string value)
    {
        return value.Replace("\r\n", "\n").Replace("\r", "\n");
    }

    private string GetTypingPlaceholder()
    {
        return _parsedContent.HasSections
            ? "Line 1: Prompt value\nLine 2: Response value\nLine 3: Example value"
            : "Retype the source content exactly as shown.";
    }

    private readonly record struct ParsedTrainingContent(
        string Prompt,
        string Response,
        string Example,
        string RetypeTarget,
        bool HasSections)
    {
        public static ParsedTrainingContent Empty { get; } = new(string.Empty, string.Empty, string.Empty, string.Empty, false);
    }

    private sealed class ModuleOption
    {
        public int Id { get; init; }

        public string Name { get; init; } = string.Empty;
    }

    private sealed class LessonOption
    {
        public int Id { get; init; }

        public string Title { get; init; } = string.Empty;

        public string ModuleName { get; init; } = string.Empty;

        public string DisplayTitle => $"{ModuleName} / {Title}";
    }
}
