@page "/Error"
@{
    Layout = null;
    Response.StatusCode = 500;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
