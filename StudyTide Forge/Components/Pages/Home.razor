@page "/"
@inject DashboardService DashboardService

<PageTitle>Dashboard</PageTitle>

@if (_snapshot is null)
{
    @if (string.IsNullOrWhiteSpace(_loadError))
    {
        <p>Loading dashboard metrics...</p>
    }
    else
    {
        <section class="panel warning-message">
            <h1>Dashboard is temporarily unavailable</h1>
            <p>@_loadError</p>
            <p class="meta-text">You can still open Practice and Flashcards while diagnostics run.</p>
        </section>
    }
}
else
{
    <section class="panel hero-panel">
        <p class="hero-kicker">Training Overview</p>
        <h1>Software Engineer + Cloud App Developer Readiness</h1>
        <p class="meta-text">Your curriculum blends C#, Azure, SQL, DevOps, and system design drills with verbatim practice and flashcards.</p>
    </section>

    <div class="metric-grid">
        <article class="metric-card">
            <h2>Total modules</h2>
            <p>@_snapshot.TotalModules</p>
        </article>
        <article class="metric-card">
            <h2>Total lessons</h2>
            <p>@_snapshot.TotalLessons</p>
        </article>
        <article class="metric-card">
            <h2>Total retype items</h2>
            <p>@_snapshot.TotalTrainingItems</p>
        </article>
        <article class="metric-card">
            <h2>Total flashcards</h2>
            <p>@_snapshot.TotalFlashcards</p>
        </article>
        <article class="metric-card">
            <h2>Combined mode entries</h2>
            <p>@GetCombinedModeEntries(_snapshot)</p>
        </article>
        <article class="metric-card">
            <h2>Unique logical items</h2>
            <p>@GetUniqueLogicalItems(_snapshot)</p>
        </article>
        <article class="metric-card">
            <h2>Items in both modes</h2>
            <p>@_snapshot.ItemsInBothModes</p>
        </article>
        <article class="metric-card">
            <h2>Retype-only items</h2>
            <p>@_snapshot.RetypeOnlyItems</p>
        </article>
        <article class="metric-card">
            <h2>Flashcard-only items</h2>
            <p>@_snapshot.FlashcardOnlyItems</p>
        </article>
        <article class="metric-card">
            <h2>Retype due</h2>
            <p>@_snapshot.BlocksDue</p>
        </article>
        <article class="metric-card">
            <h2>Flashcards due</h2>
            <p>@_snapshot.FlashcardsDue</p>
        </article>
        <article class="metric-card">
            <h2>Accuracy (7 days)</h2>
            <p>@_snapshot.AccuracyLast7Days.ToString("0.00")%</p>
        </article>
        <article class="metric-card">
            <h2>Imported content</h2>
            <p>Imported retype items: @_snapshot.ImportedTrainingItems</p>
            <p>Imported flashcards: @_snapshot.ImportedFlashcards</p>
        </article>
    </div>

    <section class="panel">
        <h2>How totals relate</h2>
        <p class="meta-text">
            Combined mode entries = Total retype items + Total flashcards = @GetCombinedModeEntries(_snapshot).
            Unique logical items = Items in both modes + Retype-only items + Flashcard-only items = @GetUniqueLogicalItems(_snapshot).
        </p>
        <p class="meta-text">
            Mirroring status:
            @if (IsPerfectlyMirrored(_snapshot))
            {
                <strong> Fully mirrored.</strong>
                <span> Every logical item is available in both Practice and Flashcards.</span>
            }
            else
            {
                <strong> Partially mirrored.</strong>
                <span> @GetMirroringCoveragePercent(_snapshot).ToString("0.00")% of logical items are in both modes.</span>
            }
        </p>
    </section>

    <section class="panel">
        <h2>Curriculum coverage by category</h2>
        <p class="meta-text">Recommended minimums are tuned for software engineering and cloud application development preparation.</p>

        <table class="data-table coverage-table">
            <thead>
                <tr>
                    <th>Category</th>
                    <th>Modules</th>
                    <th>Lessons</th>
                    <th>Training items</th>
                    <th>Recommended minimum</th>
                    <th>Additional needed</th>
                    <th>Coverage</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var coverage in _snapshot.CategoryCoverage)
                {
                    <tr>
                        <td>@coverage.Category</td>
                        <td>@coverage.Modules</td>
                        <td>@coverage.Lessons</td>
                        <td>@coverage.TrainingItems</td>
                        <td>@coverage.RecommendedMinimumTrainingItems</td>
                        <td>@coverage.AdditionalTrainingItemsNeeded</td>
                        <td>
                            <div class="coverage-meter" aria-hidden="true">
                                <span style="width:@GetCoverageWidth(coverage.CoveragePercent)"></span>
                            </div>
                            <span class="coverage-label">@coverage.CoveragePercent.ToString("0.0")%</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    <section class="panel">
        <h2>Weakest training items</h2>

        @if (_snapshot.WeakestBlocks.Count == 0)
        {
            <p>No practice attempts recorded yet.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Training item</th>
                        <th>Lesson</th>
                        <th>Avg accuracy</th>
                        <th>Attempts</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var block in _snapshot.WeakestBlocks)
                    {
                        <tr>
                            <td>@block.Title</td>
                            <td>@block.LessonTitle</td>
                            <td>@block.AverageAccuracy.ToString("0.00")%</td>
                            <td>@block.Attempts</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="panel">
        <h2>Weakest flashcards</h2>

        @if (_snapshot.WeakestFlashcards.Count == 0)
        {
            <p>No flashcard results recorded yet.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Question</th>
                        <th>Lesson</th>
                        <th>Success rate</th>
                        <th>Attempts</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var card in _snapshot.WeakestFlashcards)
                    {
                        <tr>
                            <td>@Truncate(card.Question, 100)</td>
                            <td>@card.LessonTitle</td>
                            <td>@card.SuccessRate.ToString("0.00")%</td>
                            <td>@card.Attempts</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    private DashboardSnapshot? _snapshot;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _snapshot = await DashboardService.GetSnapshotAsync();
        }
        catch (Exception exception)
        {
            _loadError = exception.Message;
            Console.Error.WriteLine($"[StudyTide] Dashboard initialization failed. {exception}");
        }
    }

    private static string Truncate(string value, int maxLength)
    {
        return value.Length <= maxLength
            ? value
            : $"{value[..maxLength]}...";
    }

    private static string GetCoverageWidth(double coveragePercent)
    {
        return $"{Math.Clamp(coveragePercent, 0, 100):0.##}%";
    }

    private static int GetCombinedModeEntries(DashboardSnapshot snapshot)
    {
        return snapshot.TotalTrainingItems + snapshot.TotalFlashcards;
    }

    private static int GetUniqueLogicalItems(DashboardSnapshot snapshot)
    {
        return snapshot.ItemsInBothModes + snapshot.RetypeOnlyItems + snapshot.FlashcardOnlyItems;
    }

    private static bool IsPerfectlyMirrored(DashboardSnapshot snapshot)
    {
        return snapshot.RetypeOnlyItems == 0 && snapshot.FlashcardOnlyItems == 0;
    }

    private static double GetMirroringCoveragePercent(DashboardSnapshot snapshot)
    {
        var uniqueItems = GetUniqueLogicalItems(snapshot);

        if (uniqueItems == 0)
        {
            return 100;
        }

        return Math.Round((double)snapshot.ItemsInBothModes / uniqueItems * 100, 2);
    }
}
