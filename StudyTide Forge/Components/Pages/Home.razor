@page "/"
@inject DashboardService DashboardService
@implements IAsyncDisposable

<PageTitle>Dashboard</PageTitle>

@if (_snapshot is null)
{
    @if (string.IsNullOrWhiteSpace(_loadError))
    {
        <p>Loading dashboard metrics...</p>
    }
    else
    {
        <section class="panel warning-message">
            <h1>Dashboard is temporarily unavailable</h1>
            <p>@_loadError</p>
            <p class="meta-text">You can still open Practice and Flashcards while diagnostics run.</p>
        </section>
    }
}
else
{
    <section class="panel hero-panel">
        <p class="hero-kicker">Training Overview</p>
        <h1>Software Engineer + Cloud App Developer Readiness</h1>
        <p class="meta-text">Your curriculum blends C#, Azure, SQL, DevOps, and system design drills with verbatim practice and flashcards.</p>
    </section>

    <div class="metric-grid">
        <article class="metric-card">
            <h2>Total modules</h2>
            <p>@_snapshot.TotalModules</p>
        </article>
        <article class="metric-card">
            <h2>Total lessons</h2>
            <p>@_snapshot.TotalLessons</p>
        </article>
        <article class="metric-card">
            <h2>Total training items</h2>
            <p>@_snapshot.TotalTrainingItems</p>
        </article>
        <article class="metric-card">
            <h2>Total flashcards</h2>
            <p>@_snapshot.TotalFlashcards</p>
        </article>
        <article class="metric-card">
            <h2>Retype due</h2>
            <p>@_snapshot.BlocksDue</p>
        </article>
        <article class="metric-card">
            <h2>Flashcards due</h2>
            <p>@_snapshot.FlashcardsDue</p>
        </article>
        <article class="metric-card">
            <h2>Accuracy (7 days)</h2>
            <p>@_snapshot.AccuracyLast7Days.ToString("0.00")%</p>
        </article>
    </div>

    <section class="panel">
        <h2>Completion Progress</h2>
        <div class="completion-grid">
            <article class="completion-card">
                <div class="completion-head">
                    <h3>Study Library</h3>
                    <span class="completion-percent">@_snapshot.StudyLibraryCompletionPercent.ToString("0.0")%</span>
                </div>
                <p class="completion-detail">@_snapshot.CompletedStudyLessons of @_snapshot.TotalLessons lessons completed</p>
                <div class="coverage-meter" aria-hidden="true">
                    <span style="width:@GetCoverageWidth(_snapshot.StudyLibraryCompletionPercent)"></span>
                </div>
            </article>
            <article class="completion-card">
                <div class="completion-head">
                    <h3>Flashcards</h3>
                    <span class="completion-percent">@_snapshot.FlashcardsCompletionPercent.ToString("0.0")%</span>
                </div>
                <p class="completion-detail">@_snapshot.CompletedFlashcards of @_snapshot.TotalFlashcards cards reviewed</p>
                <div class="coverage-meter" aria-hidden="true">
                    <span style="width:@GetCoverageWidth(_snapshot.FlashcardsCompletionPercent)"></span>
                </div>
            </article>
            <article class="completion-card">
                <div class="completion-head">
                    <h3>Practice</h3>
                    <span class="completion-percent">@_snapshot.PracticeCompletionPercent.ToString("0.0")%</span>
                </div>
                <p class="completion-detail">@_snapshot.CompletedPracticeItems of @_snapshot.TotalTrainingItems items practiced</p>
                <div class="coverage-meter" aria-hidden="true">
                    <span style="width:@GetCoverageWidth(_snapshot.PracticeCompletionPercent)"></span>
                </div>
            </article>
        </div>
    </section>

    <section class="panel">
        <h2>Curriculum coverage by category</h2>
        <p class="meta-text">Recommended minimums are tuned for software engineering and cloud application development preparation.</p>

        <table class="data-table coverage-table">
            <thead>
                <tr>
                    <th>Category</th>
                    <th>Modules</th>
                    <th>Lessons</th>
                    <th>Training items</th>
                    <th>Recommended minimum</th>
                    <th>Additional needed</th>
                    <th>Coverage</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var coverage in _snapshot.CategoryCoverage)
                {
                    <tr>
                        <td>@coverage.Category</td>
                        <td>@coverage.Modules</td>
                        <td>@coverage.Lessons</td>
                        <td>@coverage.TrainingItems</td>
                        <td>@coverage.RecommendedMinimumTrainingItems</td>
                        <td>@coverage.AdditionalTrainingItemsNeeded</td>
                        <td>
                            <div class="coverage-meter" aria-hidden="true">
                                <span style="width:@GetCoverageWidth(coverage.CoveragePercent)"></span>
                            </div>
                            <span class="coverage-label">@coverage.CoveragePercent.ToString("0.0")%</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    <section class="panel">
        <h2>Weakest training items</h2>

        @if (_snapshot.WeakestBlocks.Count == 0)
        {
            <p>No practice attempts recorded yet.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Training item</th>
                        <th>Lesson</th>
                        <th>Avg accuracy</th>
                        <th>Attempts</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var block in _snapshot.WeakestBlocks)
                    {
                        <tr>
                            <td>@block.Title</td>
                            <td>@block.LessonTitle</td>
                            <td>@block.AverageAccuracy.ToString("0.00")%</td>
                            <td>@block.Attempts</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="panel">
        <h2>Weakest flashcards</h2>

        @if (_snapshot.WeakestFlashcards.Count == 0)
        {
            <p>No flashcard results recorded yet.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Question</th>
                        <th>Lesson</th>
                        <th>Success rate</th>
                        <th>Attempts</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var card in _snapshot.WeakestFlashcards)
                    {
                        <tr>
                            <td>@Truncate(card.Question, 100)</td>
                            <td>@card.LessonTitle</td>
                            <td>@card.SuccessRate.ToString("0.00")%</td>
                            <td>@card.Attempts</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    private DashboardSnapshot? _snapshot;
    private string? _loadError;
    private CancellationTokenSource? _refreshCancellation;
    private Task? _refreshTask;

    protected override async Task OnInitializedAsync()
    {
        _refreshCancellation = new CancellationTokenSource();

        await LoadSnapshotAsync();

        _refreshTask = StartAutoRefreshAsync(_refreshCancellation.Token);
    }

    private async Task LoadSnapshotAsync()
    {
        try
        {
            _snapshot = await DashboardService.GetSnapshotAsync();
            _loadError = null;
        }
        catch (Exception exception)
        {
            _loadError = exception.Message;
            Console.Error.WriteLine($"[StudyTide] Dashboard load failed. {exception}");
        }
    }

    private async Task StartAutoRefreshAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(15));

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                DashboardSnapshot? refreshed = null;
                string? refreshError = null;

                try
                {
                    refreshed = await DashboardService.GetSnapshotAsync();
                }
                catch (Exception exception)
                {
                    refreshError = exception.Message;
                    Console.Error.WriteLine($"[StudyTide] Dashboard refresh failed. {exception}");
                }

                if (cancellationToken.IsCancellationRequested)
                {
                    break;
                }

                await InvokeAsync(() =>
                {
                    if (refreshed is not null)
                    {
                        _snapshot = refreshed;
                        _loadError = null;
                    }
                    else if (!string.IsNullOrWhiteSpace(refreshError))
                    {
                        _loadError = refreshError;
                    }

                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
            // Expected when leaving the page.
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_refreshCancellation is null)
        {
            return;
        }

        await _refreshCancellation.CancelAsync();

        if (_refreshTask is not null)
        {
            await _refreshTask;
        }

        _refreshCancellation.Dispose();
        _refreshCancellation = null;
    }

    private static string Truncate(string value, int maxLength)
    {
        return value.Length <= maxLength
            ? value
            : $"{value[..maxLength]}...";
    }

    private static string GetCoverageWidth(double coveragePercent)
    {
        return $"{Math.Clamp(coveragePercent, 0, 100):0.##}%";
    }

}
