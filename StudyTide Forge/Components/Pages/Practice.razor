@page "/practice"
@inject IDbContextFactory<ForgeDbContext> DbFactory
@inject PracticeService PracticeService

<PageTitle>Practice</PageTitle>

<h1>Verbatim Practice</h1>

<section class="practice-progress">
    <div class="practice-progress-head">
        <span>Session Progress</span>
        <span>@GetProgressLabel()</span>
    </div>
    <div class="practice-progress-bar">
        <span style="width:@GetProgressWidth()"></span>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <p class="status-message">@_statusMessage</p>
}

<section class="panel">
    <div class="scope-header">
        <h2>Scope</h2>
        <button type="button" class="danger" @onclick="ShowResetWarning">Reset</button>
    </div>

    <div class="filter-grid">
        <div>
            <label for="moduleScope">Module</label>
            <select id="moduleScope" value="@(_selectedModuleId?.ToString() ?? "all")" @onchange="OnModuleChangedAsync">
                <option value="all">All modules</option>
                @foreach (var module in _modules)
                {
                    <option value="@module.Id">@module.Name</option>
                }
            </select>
        </div>

        <div>
            <label for="lessonScope">Lesson</label>
            <select id="lessonScope" value="@(_selectedLessonId?.ToString() ?? "all")" @onchange="OnLessonChangedAsync">
                <option value="all">All lessons</option>
                @foreach (var lesson in _lessons)
                {
                    <option value="@lesson.Id">@(_selectedModuleId.HasValue ? lesson.Title : lesson.DisplayTitle)</option>
                }
            </select>
        </div>
    </div>

    <div class="actions">
        <button @onclick="LoadScopeDueBlockAsync">Load Next Due Question</button>
        <span class="meta-text">Mode: @(_isRandomMode ? "Random Lock" : "Due")</span>
    </div>
</section>

<section class="panel instruction-panel">
    <h2>Retype Workflow</h2>
    <div class="instruction-grid">
        <article class="instruction-step">
            <span class="step-badge">1</span>
            <h3>Load a due question</h3>
            <p>Choose module/lesson scope, then load the next due training item.</p>
        </article>
        <article class="instruction-step">
            <span class="step-badge">2</span>
            <h3>Read all three sections</h3>
            <p>Review Prompt, Response, and Study Cue so context is clear before typing.</p>
        </article>
        <article class="instruction-step">
            <span class="step-badge">3</span>
            <h3>Retype values only</h3>
            <p>Type section text in order. Do not type section labels.</p>
        </article>
        <article class="instruction-step">
            <span class="step-badge">4</span>
            <h3>Use Summary</h3>
            <p>Submit to view a brief summary bubble and move directly to the next question.</p>
        </article>
    </div>
</section>

@if (_currentBlock is null)
{
    <section class="panel">
        <p>No training item found in the selected scope.</p>
    </section>
}
else
{
    <section class="panel">
        <h2>@GetCurrentHeading()</h2>

        <div class="lesson-meta-row">
            <p class="meta-text">
                Lesson: @_currentBlock.Lesson?.Title |
                Difficulty: @_currentBlock.Difficulty
            </p>
            <label class="checkbox-inline" title="Flag this lesson for focused review">
                <input type="checkbox" checked="@_isCurrentLessonFlagged" @onchange="OnCurrentLessonFlagChangedAsync" />
                Flag lesson
            </label>
        </div>

        <div class="practice-grid">
            <article>
                <h3>Training content</h3>

                @if (_parsedContent.HasSections)
                {
                    <div class="training-sections">
                        <section class="training-section">
                            <h4>Prompt</h4>
                            <pre class="training-content">@_parsedContent.Prompt</pre>
                        </section>
                        <section class="training-section">
                            <h4>Response</h4>
                            <pre class="training-content">@_parsedContent.Response</pre>
                        </section>
                        <section class="training-section">
                            <h4>Study Cue</h4>
                            <pre class="training-content">@_parsedContent.Example</pre>
                        </section>
                        <section class="training-section study-expanded">
                            <h4>Expanded Context</h4>
                            <ul class="study-cue-list">
                                @foreach (var point in _parsedContent.ExpandedCues)
                                {
                                    <li>@point</li>
                                }
                            </ul>
                        </section>
                    </div>
                    <p class="meta-text retype-note">Retype only the text values above in this order: Prompt line, Response line, Study Cue line.</p>
                }
                else
                {
                    <pre class="training-content">@_parsedContent.RetypeTarget</pre>
                    <p class="meta-text retype-note">Retype exactly what is shown in the training content panel.</p>
                }
            </article>

            <article>
                <h3>Your verbatim retype</h3>
                <InputTextArea @bind-Value="_typedText" rows="18" class="typing-box" placeholder="@GetTypingPlaceholder()" />
                <div class="typing-hints">
                    <span>Expected chars: @_parsedContent.RetypeTarget.Length</span>
                    <span>Typed chars: @_typedText.Length</span>
                </div>
            </article>
        </div>

        <div class="actions">
            <button @onclick="SubmitAttemptAsync">Submit Attempt</button>
            <button class="secondary" @onclick="GoBack" disabled="@(!CanGoBack)">Back</button>
            <button class="secondary" @onclick="SkipCurrentBlockAsync">Skip</button>
            <button class="secondary" @onclick="StartRandomModeAsync">Random</button>
            <button @onclick="LoadNextQuestionAsync">Next</button>
        </div>
    </section>
}

@if (_isSummaryModalVisible && _evaluation is not null)
{
    <ModalShell IsVisible="_isSummaryModalVisible"
                Title="Summary"
                PanelClass="summary-modal">
        <ChildContent>
            <p class="summary-brief">@GetSummaryBrief()</p>

            <div class="metric-grid summary-metrics">
                <article class="metric-card">
                    <h3>Accuracy</h3>
                    <p>@_evaluation.AccuracyPercent.ToString("0.00")%</p>
                </article>
                <article class="metric-card">
                    <h3>Error count</h3>
                    <p>@_evaluation.ErrorCount</p>
                </article>
                <article class="metric-card">
                    <h3>Missing chars</h3>
                    <p>@_evaluation.MissingCharacters</p>
                </article>
                <article class="metric-card">
                    <h3>Extra chars</h3>
                    <p>@_evaluation.ExtraCharacters</p>
                </article>
                <article class="metric-card">
                    <h3>First mismatch index</h3>
                    <p>@(_evaluation.FirstMismatchIndex?.ToString() ?? "None")</p>
                </article>
            </div>

            @if (_evaluation.MismatchedLines.Count > 0)
            {
                <h3>Top line differences</h3>
                <ul class="summary-diff-list">
                    @foreach (var mismatch in _evaluation.MismatchedLines.Take(3))
                    {
                        <li>
                            <strong>Line @mismatch.LineNumber</strong><br />
                            <span>Expected: @mismatch.SourceLine</span><br />
                            <span>Typed: @mismatch.TypedLine</span>
                        </li>
                    }
                </ul>
            }
        </ChildContent>
        <Actions>
            <button class="secondary" @onclick="CloseSummaryModal">Close</button>
            <button @onclick="OnSummaryNextAsync">Next</button>
        </Actions>
    </ModalShell>
}

@if (_showResetWarning)
{
    <ModalShell IsVisible="_showResetWarning"
                Title="Reset Practice Session"
                PanelClass="reset-warning-modal">
        <ChildContent>
            <p class="reset-warning-text">
                <span class="warning-bang">!</span>
                WARNING! Resetting will restart the entire Practice session. Do you wish to continue?
            </p>
        </ChildContent>
        <Actions>
            <button class="secondary" @onclick="CloseResetWarning">Cancel</button>
            <button class="danger" @onclick="ResetPracticeSessionAsync">Reset Now</button>
        </Actions>
    </ModalShell>
}

@code {
    private readonly List<ModuleOption> _modules = [];
    private readonly List<LessonOption> _lessons = [];
    private readonly List<TrainingBlock> _history = [];
    private readonly HashSet<int> _excludedBlockIds = [];
    private readonly HashSet<int> _sessionVisitedBlockIds = [];

    private int? _selectedModuleId;
    private int? _selectedLessonId;

    private TrainingBlock? _currentBlock;
    private PracticeEvaluation? _evaluation;
    private DisplayTrainingContent _parsedContent = DisplayTrainingContent.Empty;
    private string _typedText = string.Empty;
    private string? _statusMessage;
    private int _historyIndex = -1;
    private bool _isCurrentLessonFlagged;
    private bool _isRandomMode;
    private bool _isSummaryModalVisible;
    private bool _showResetWarning;
    private int _scopeTotalCount;

    private bool CanGoBack => _historyIndex > 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadModulesAsync();
            await LoadLessonsAsync();
            await LoadScopeDueBlockAsync();
        }
        catch (Exception exception)
        {
            HandleUiException("Unable to initialize practice data.", exception);
        }
    }

    private async Task LoadModulesAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var modules = await db.TrainingModules
            .AsNoTracking()
            .OrderBy(x => x.Category)
            .ThenBy(x => x.Name)
            .Select(x => new ModuleOption
            {
                Id = x.Id,
                Name = x.Name
            })
            .ToListAsync();

        _modules.Clear();
        _modules.AddRange(modules);
    }

    private async Task LoadLessonsAsync()
    {
        _lessons.Clear();

        await using var db = await DbFactory.CreateDbContextAsync();

        var query = db.TrainingLessons
            .AsNoTracking()
            .Include(x => x.Module)
            .AsQueryable();

        if (_selectedModuleId.HasValue)
        {
            query = query.Where(x => x.ModuleId == _selectedModuleId.Value);
        }

        var lessons = await query
            .OrderBy(x => x.Module!.Name)
            .ThenBy(x => x.OrderIndex)
            .Select(x => new LessonOption
            {
                Id = x.Id,
                Title = x.Title,
                ModuleName = x.Module!.Name
            })
            .ToListAsync();

        _lessons.AddRange(lessons);
    }

    private async Task OnModuleChangedAsync(ChangeEventArgs eventArgs)
    {
        _selectedModuleId = ParseNullableInt(eventArgs.Value?.ToString());
        _selectedLessonId = null;

        await LoadLessonsAsync();
        await LoadScopeDueBlockAsync();
    }

    private async Task OnLessonChangedAsync(ChangeEventArgs eventArgs)
    {
        _selectedLessonId = ParseNullableInt(eventArgs.Value?.ToString());
        await LoadScopeDueBlockAsync();
    }

    private async Task LoadScopeDueBlockAsync()
    {
        _isRandomMode = false;
        ResetSessionState();
        await RefreshScopeCountAsync();
        await LoadDueBlockCoreAsync(excludeCurrent: false, "Training question loaded.");
    }

    private async Task StartRandomModeAsync()
    {
        _isRandomMode = true;
        ResetSessionState();
        await RefreshScopeCountAsync();
        await LoadRandomBlockCoreAsync(excludeCurrent: true, "Random lock started.");
    }

    private async Task LoadNextQuestionAsync()
    {
        if (_currentBlock is null)
        {
            _statusMessage = "Load a training question first.";
            return;
        }

        if (_isRandomMode)
        {
            await LoadRandomBlockCoreAsync(excludeCurrent: true, "Loaded next random question.");
            return;
        }

        await LoadDueBlockCoreAsync(excludeCurrent: true, "Loaded next due question.");
    }

    private async Task SkipCurrentBlockAsync()
    {
        if (_currentBlock is null)
        {
            _statusMessage = "Load a training question first.";
            return;
        }

        if (_isRandomMode)
        {
            await LoadRandomBlockCoreAsync(excludeCurrent: true, "Question skipped. Loaded next random question.");
            return;
        }

        await LoadDueBlockCoreAsync(excludeCurrent: true, "Question skipped. Loaded next due question.");
    }

    private async Task LoadDueBlockCoreAsync(bool excludeCurrent, string successMessage)
    {
        try
        {
            _isSummaryModalVisible = false;

            if (excludeCurrent && _currentBlock is not null)
            {
                _excludedBlockIds.Add(_currentBlock.Id);
            }

            var block = await PracticeService.GetNextDueBlockAsync(
                _selectedModuleId,
                _selectedLessonId,
                _excludedBlockIds);

            if (block is null && _excludedBlockIds.Count > 0)
            {
                _excludedBlockIds.Clear();
                block = await PracticeService.GetNextDueBlockAsync(_selectedModuleId, _selectedLessonId);
            }

            if (block is null)
            {
                SetCurrentBlock(null, appendToHistory: false);
                _statusMessage = "No due training item available in this scope.";
                return;
            }

            SetCurrentBlock(block, appendToHistory: true);
            _statusMessage = successMessage;
        }
        catch (Exception exception)
        {
            HandleUiException("Unable to load the next training item.", exception);
        }
    }

    private async Task LoadRandomBlockCoreAsync(bool excludeCurrent, string successMessage)
    {
        try
        {
            _isSummaryModalVisible = false;

            if (excludeCurrent && _currentBlock is not null)
            {
                _excludedBlockIds.Add(_currentBlock.Id);
            }

            var block = await PracticeService.GetRandomBlockAsync(
                _selectedModuleId,
                _selectedLessonId,
                dueOnly: true,
                excludedBlockIds: _excludedBlockIds);

            if (block is null)
            {
                if (_excludedBlockIds.Count == 0)
                {
                    SetCurrentBlock(null, appendToHistory: false);
                    _statusMessage = "No training item available in this scope.";
                    return;
                }

                _statusMessage = "Random lock complete for this scope. Click Random to reshuffle.";
                return;
            }

            SetCurrentBlock(block, appendToHistory: true);
            _statusMessage = successMessage;
        }
        catch (Exception exception)
        {
            HandleUiException("Unable to load a random training item.", exception);
        }
    }

    private void GoBack()
    {
        if (!CanGoBack)
        {
            return;
        }

        _isSummaryModalVisible = false;
        _historyIndex--;
        var previous = _history[_historyIndex];
        SetCurrentBlock(previous, appendToHistory: false);
        _statusMessage = "Showing previous question.";
    }

    private async Task SubmitAttemptAsync()
    {
        if (_currentBlock is null)
        {
            _statusMessage = "Load a training question first.";
            return;
        }

        try
        {
            _evaluation = PracticeService.Evaluate(_parsedContent.RetypeTarget, _typedText);
            await PracticeService.SaveAttemptAsync(_currentBlock.Id, _typedText, _evaluation);

            _isSummaryModalVisible = true;
            _statusMessage = "Attempt saved and schedule updated.";
        }
        catch (Exception exception)
        {
            HandleUiException("Unable to submit this attempt.", exception);
        }
    }

    private void CloseSummaryModal()
    {
        _isSummaryModalVisible = false;
    }

    private async Task OnSummaryNextAsync()
    {
        _isSummaryModalVisible = false;
        await LoadNextQuestionAsync();
    }

    private void ShowResetWarning()
    {
        _showResetWarning = true;
    }

    private void CloseResetWarning()
    {
        _showResetWarning = false;
    }

    private async Task ResetPracticeSessionAsync()
    {
        _showResetWarning = false;
        _isSummaryModalVisible = false;
        _isRandomMode = false;
        ResetSessionState();
        await RefreshScopeCountAsync();
        await LoadDueBlockCoreAsync(excludeCurrent: false, "Practice session reset.");
    }

    private async Task OnCurrentLessonFlagChangedAsync(ChangeEventArgs eventArgs)
    {
        if (_currentBlock?.LessonId is not int lessonId)
        {
            return;
        }

        var isFlagged = ParseCheckboxValue(eventArgs.Value);

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var lesson = await db.TrainingLessons.FirstOrDefaultAsync(x => x.Id == lessonId);

            if (lesson is null)
            {
                return;
            }

            lesson.IsFlagged = isFlagged;
            await db.SaveChangesAsync();

            _isCurrentLessonFlagged = isFlagged;

            if (_currentBlock.Lesson is not null)
            {
                _currentBlock.Lesson.IsFlagged = isFlagged;
            }

            foreach (var block in _history.Where(x => x.LessonId == lessonId && x.Lesson is not null))
            {
                block.Lesson!.IsFlagged = isFlagged;
            }

            _statusMessage = isFlagged
                ? "Lesson flagged for focused review."
                : "Lesson removed from flagged materials.";
        }
        catch (Exception exception)
        {
            HandleUiException("Unable to update lesson flag.", exception);
        }
    }

    private static bool ParseCheckboxValue(object? value)
    {
        if (value is bool boolValue)
        {
            return boolValue;
        }

        if (value is string stringValue && bool.TryParse(stringValue, out var parsed))
        {
            return parsed;
        }

        return false;
    }

    private void SetCurrentBlock(TrainingBlock? block, bool appendToHistory)
    {
        _currentBlock = block;
        _typedText = string.Empty;
        _evaluation = null;
        _isSummaryModalVisible = false;

        if (block is null)
        {
            _parsedContent = DisplayTrainingContent.Empty;
            _isCurrentLessonFlagged = false;
            return;
        }

        _parsedContent = ParseTrainingContent(block.Content);
        _isCurrentLessonFlagged = block.Lesson?.IsFlagged ?? false;
        _sessionVisitedBlockIds.Add(block.Id);

        if (!appendToHistory)
        {
            return;
        }

        if (_historyIndex < _history.Count - 1)
        {
            _history.RemoveRange(_historyIndex + 1, _history.Count - (_historyIndex + 1));
        }

        if (_history.Count > 0 && _history[^1].Id == block.Id)
        {
            _history[_history.Count - 1] = block;
            _historyIndex = _history.Count - 1;
            return;
        }

        _history.Add(block);
        _historyIndex = _history.Count - 1;
    }

    private static int? ParseNullableInt(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || string.Equals(value, "all", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        return int.TryParse(value, out var parsed)
            ? parsed
            : null;
    }

    private static DisplayTrainingContent ParseTrainingContent(string content)
    {
        var normalized = TrainingContentFormatter.NormalizeLineEndings(content).Trim();

        if (!TrainingContentFormatter.TryParseLabeledSections(normalized, out var sections))
        {
            return new DisplayTrainingContent(string.Empty, string.Empty, string.Empty, normalized, false, []);
        }

        var oriented = TrainingContentFormatter.ReversePromptResponse(sections);
        var retypeTarget = TrainingContentFormatter.BuildRetypeTarget(oriented);
        return new DisplayTrainingContent(
            oriented.Prompt,
            oriented.Response,
            oriented.Example,
            retypeTarget,
            true,
            BuildExpandedCues(oriented));
    }

    private static IReadOnlyList<string> BuildExpandedCues(ParsedTrainingContent sections)
    {
        var points = new List<string>();

        if (!string.IsNullOrWhiteSpace(sections.Response))
        {
            points.Add($"Core concept: {sections.Response}");
        }

        if (!string.IsNullOrWhiteSpace(sections.Prompt))
        {
            points.Add($"Recognition cue: {sections.Prompt}");
        }

        if (!string.IsNullOrWhiteSpace(sections.Example))
        {
            points.Add($"Study cue: {sections.Example}");
        }

        return points;
    }

    private string GetTypingPlaceholder()
    {
        return _parsedContent.HasSections
            ? "Line 1: Prompt value\nLine 2: Response value\nLine 3: Study Cue value"
            : "Retype the source content exactly as shown.";
    }

    private string GetCurrentHeading()
    {
        if (_parsedContent.HasSections && !string.IsNullOrWhiteSpace(_parsedContent.Prompt))
        {
            return _parsedContent.Prompt;
        }

        return _currentBlock?.Title ?? "Practice";
    }

    private string GetProgressLabel()
    {
        if (_scopeTotalCount <= 0)
        {
            return "0 / 0";
        }

        var visitedCount = Math.Min(_sessionVisitedBlockIds.Count, _scopeTotalCount);
        return $"{visitedCount} / {_scopeTotalCount}";
    }

    private string GetProgressWidth()
    {
        if (_scopeTotalCount <= 0)
        {
            return "0%";
        }

        var visitedCount = Math.Min(_sessionVisitedBlockIds.Count, _scopeTotalCount);
        var percent = (visitedCount / (double)_scopeTotalCount) * 100;
        return $"{percent:0.##}%";
    }

    private string GetSummaryBrief()
    {
        if (_evaluation is null)
        {
            return "No summary available.";
        }

        if (_evaluation.ErrorCount == 0)
        {
            return "Perfect attempt. All characters and lines matched exactly.";
        }

        return $"Accuracy {_evaluation.AccuracyPercent:0.00}% with {_evaluation.ErrorCount} total edits needed.";
    }

    private void HandleUiException(string context, Exception exception)
    {
        _statusMessage = $"{context} {exception.Message}";
        Console.Error.WriteLine($"[StudyTide] {context} {exception}");
    }

    private void ResetSessionState()
    {
        _history.Clear();
        _excludedBlockIds.Clear();
        _sessionVisitedBlockIds.Clear();
        _historyIndex = -1;
        _typedText = string.Empty;
        _evaluation = null;
    }

    private async Task RefreshScopeCountAsync()
    {
        try
        {
            _scopeTotalCount = await PracticeService.GetBlockCountAsync(_selectedModuleId, _selectedLessonId);
        }
        catch (Exception exception)
        {
            _scopeTotalCount = 0;
            HandleUiException("Unable to load practice progress.", exception);
        }
    }

    private readonly record struct DisplayTrainingContent(
        string Prompt,
        string Response,
        string Example,
        string RetypeTarget,
        bool HasSections,
        IReadOnlyList<string> ExpandedCues)
    {
        public static DisplayTrainingContent Empty { get; } = new(string.Empty, string.Empty, string.Empty, string.Empty, false, []);
    }

    private sealed class ModuleOption
    {
        public int Id { get; init; }

        public string Name { get; init; } = string.Empty;
    }

    private sealed class LessonOption
    {
        public int Id { get; init; }

        public string Title { get; init; } = string.Empty;

        public string ModuleName { get; init; } = string.Empty;

        public string DisplayTitle => $"{ModuleName} / {Title}";
    }
}
