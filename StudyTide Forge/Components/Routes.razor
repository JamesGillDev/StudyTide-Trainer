<Router AppAssembly="@typeof(MauiProgram).Assembly">
    <Found Context="routeData">
        <ErrorBoundary @ref="_errorBoundary" OnError="HandleError">
            <ChildContent>
                <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
                <FocusOnNavigate RouteData="@routeData" Selector="h1" />
            </ChildContent>
            <ErrorContent>
                <LayoutView Layout="@typeof(MainLayout)">
                    <section class="panel warning-message">
                        <h1>Something went wrong</h1>
                        <p>The page hit an unexpected error. Click recover to keep training without restarting.</p>
                        @if (_lastError is not null)
                        {
                            <p class="meta-text">Details: @_lastError.Message</p>
                        }
                        <div class="actions">
                            <button type="button" @onclick="Recover">Recover</button>
                        </div>
                    </section>
                </LayoutView>
            </ErrorContent>
        </ErrorBoundary>
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(MainLayout)">
            <h1>Page not found</h1>
            <p>The requested page does not exist.</p>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private ErrorBoundary? _errorBoundary;
    private Exception? _lastError;

    private void HandleError(Exception exception)
    {
        _lastError = exception;
    }

    private void Recover()
    {
        _lastError = null;
        _errorBoundary?.Recover();
    }
}
